# Copy backend/.env.example to backend/.env for backend-only local execution.
# Root-level docker-compose uses these defaults.
MYSQL_DATABASE=today_gift
MYSQL_USER=today_gift
MYSQL_PASSWORD=today_gift
MYSQL_ROOT_PASSWORD=today_gift_root
DATABASE_URL=mysql+pymysql://today_gift:today_gift@127.0.0.1:3306/today_gift
